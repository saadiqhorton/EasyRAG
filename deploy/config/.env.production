# RAG Knowledge Base Framework - Production Environment
# WARNING: Use strong passwords and secure secrets management

# =============================================================================
# REQUIRED - Database Configuration
# =============================================================================
POSTGRES_USER=ragkb
POSTGRES_PASSWORD=CHANGE_ME_USE_STRONG_RANDOM_PASSWORD_32_CHARS
POSTGRES_DB=ragkb_production
POSTGRES_URL=postgresql+asyncpg://ragkb:CHANGE_ME_USE_STRONG_RANDOM_PASSWORD_32_CHARS@postgres:5432/ragkb_production

# =============================================================================
# REQUIRED - Vector Database (Qdrant)
# =============================================================================
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=CHANGE_ME_OPTIONAL_BUT_RECOMMENDED

# =============================================================================
# REQUIRED - Authentication (Production)
# =============================================================================
# MANDATORY: Generate with: openssl rand -hex 32
# ALL API WRITE operations require Bearer token authentication
# This protects document upload, delete, replace, search, and ask endpoints
API_KEY=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_HEX_32

# =============================================================================
# REQUIRED - Answer Generation LLM
# =============================================================================
# For production with OpenAI:
# ANSWER_LLM_BASE_URL=https://api.openai.com/v1
# ANSWER_LLM_MODEL=gpt-4o
# ANSWER_LLM_API_KEY=sk-...

# For production with self-hosted Ollama:
ANSWER_LLM_BASE_URL=http://ollama:11434/v1
ANSWER_LLM_MODEL=llama3.2
ANSWER_LLM_API_KEY=

# =============================================================================
# OPTIONAL - Model Configuration
# =============================================================================
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSIONS=384
RERANKER_MODEL_NAME=cross-encoder/ms-marco-MiniLM-L-6-v2

# HuggingFace token (STRONGLY RECOMMENDED for production)
HF_TOKEN=

# =============================================================================
# OPTIONAL - Storage Configuration
# =============================================================================
STORAGE_PATH=/data/storage
MAX_UPLOAD_SIZE_MB=100

# =============================================================================
# OPTIONAL - Worker Configuration
# =============================================================================
WORKER_POLL_INTERVAL=2.0

# =============================================================================
# OPTIONAL - Chunking Configuration
# =============================================================================
CHUNK_MAX_TOKENS=500
CHUNK_OVERLAP_TOKENS=150

# =============================================================================
# OPTIONAL - Retrieval Configuration
# =============================================================================
ABSTENTION_SCORE_THRESHOLD=0.3
OCR_CONFIDENCE_THRESHOLD=0.5

# =============================================================================
# OPTIONAL - API Configuration
# =============================================================================
CORS_ORIGINS=https://yourdomain.com,https://app.yourdomain.com

# =============================================================================
# OPTIONAL - Logging
# =============================================================================
LOG_LEVEL=WARNING

# =============================================================================
# PRODUCTION SAFETY
# =============================================================================
# Never use create_all fallback in production
CREATE_ALL_FALLBACK=false
