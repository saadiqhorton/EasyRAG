# RAG Knowledge Base Framework - Staging Environment
# Use for pre-production testing

# =============================================================================
# REQUIRED - Database Configuration
# =============================================================================
POSTGRES_USER=ragkb_staging
POSTGRES_PASSWORD=change_me_strong_staging_password
POSTGRES_DB=ragkb_staging
POSTGRES_URL=postgresql+asyncpg://ragkb_staging:change_me_strong_staging_password@postgres:5432/ragkb_staging

# =============================================================================
# REQUIRED - Vector Database (Qdrant)
# =============================================================================
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=

# =============================================================================
# REQUIRED - Authentication (Staging)
# =============================================================================
# Generate with: openssl rand -hex 32
# ALL API WRITE operations require Bearer token authentication
API_KEY=CHANGE_ME_STAGING_API_KEY_64_CHARS_HEX

# =============================================================================
# REQUIRED - Answer Generation LLM
# =============================================================================
# For staging, use a smaller/faster model to save costs
ANSWER_LLM_BASE_URL=http://ollama:11434/v1
ANSWER_LLM_MODEL=llama3.2
ANSWER_LLM_API_KEY=

# =============================================================================
# OPTIONAL - Model Configuration
# =============================================================================
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSIONS=384
RERANKER_MODEL_NAME=cross-encoder/ms-marco-MiniLM-L-6-v2

# HuggingFace token (recommended for staging)
HF_TOKEN=

# =============================================================================
# OPTIONAL - Storage Configuration
# =============================================================================
STORAGE_PATH=/data/storage
MAX_UPLOAD_SIZE_MB=100

# =============================================================================
# OPTIONAL - Worker Configuration
# =============================================================================
WORKER_POLL_INTERVAL=2.0

# =============================================================================
# OPTIONAL - Chunking Configuration
# =============================================================================
CHUNK_MAX_TOKENS=500
CHUNK_OVERLAP_TOKENS=150

# =============================================================================
# OPTIONAL - Retrieval Configuration
# =============================================================================
ABSTENTION_SCORE_THRESHOLD=0.3
OCR_CONFIDENCE_THRESHOLD=0.5

# =============================================================================
# OPTIONAL - API Configuration
# =============================================================================
CORS_ORIGINS=https://staging.example.com,https://app.staging.example.com

# =============================================================================
# OPTIONAL - Logging
# =============================================================================
LOG_LEVEL=INFO

# =============================================================================
# STAGING SPECIFIC
# =============================================================================
# Don't use create_all fallback in staging
CREATE_ALL_FALLBACK=false
