# EasyRAG Configuration
# Copy to .env and customize before starting.

# ── Database (auto-detected, no manual config needed for local install) ──
# For no-Docker local installs: SQLite is used automatically (no setup needed).
# For Docker installs: set DATABASE_URL or POSTGRES_URL to your PostgreSQL instance.
# DATABASE_URL=sqlite+aiosqlite:///./easyrag.db
# DATABASE_URL=postgresql+asyncpg://ragkb:password@localhost:5432/ragkb
POSTGRES_USER=ragkb
POSTGRES_PASSWORD=changeme
POSTGRES_DB=ragkb

# ── LLM Provider ─────────────────────────────────────────────────
# Supported: ollama, openai, anthropic, gemini, openai_compatible
LLM_PROVIDER=ollama

# LLM base URL and model (required for all providers)
ANSWER_LLM_BASE_URL=http://localhost:11434/v1
ANSWER_LLM_MODEL=llama3.2

# API key (required for openai, anthropic, gemini; optional for ollama)
ANSWER_LLM_API_KEY=

# ── Qdrant (auto-managed for local install) ──────────────────────
QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=

# ── Optional ────────────────────────────────────────────────────────
# EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
# EMBEDDING_DIMENSIONS=384
# CORS_ORIGINS=http://localhost:3000
# MAX_UPLOAD_SIZE_MB=50
# HF_TOKEN=
