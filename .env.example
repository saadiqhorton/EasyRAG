# EasyRAG Configuration
# Copy to .env and customize before starting.
# Only the LLM settings below are required — everything else has defaults.

# ── LLM (Required) ──────────────────────────────────────────────
# Point to your LLM server. For local Ollama: http://host.docker.internal:11434/v1
# For OpenAI: https://api.openai.com/v1  (set ANSWER_LLM_API_KEY too)
ANSWER_LLM_BASE_URL=http://host.docker.internal:11434/v1
ANSWER_LLM_MODEL=llama3.2
ANSWER_LLM_API_KEY=

# ── Database (Defaults are fine for local use) ──────────────────
POSTGRES_USER=ragkb
POSTGRES_PASSWORD=changeme
POSTGRES_DB=ragkb

# ── Optional ────────────────────────────────────────────────────
# QDRANT_API_KEY=
# EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
# EMBEDDING_DIMENSIONS=384
# CORS_ORIGINS=http://localhost:3000
# MAX_UPLOAD_SIZE_MB=50
