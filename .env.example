# EasyRAG Configuration
# Copy to .env and customize before starting.
# Only the LLM provider and model are required — everything else has defaults.

# ── LLM Provider (Required) ─────────────────────────────────────
# Supported: ollama, openai, anthropic, gemini, openai_compatible
LLM_PROVIDER=ollama

# LLM base URL and model (required for all providers)
#   ollama:              http://host.docker.internal:11434/v1  | llama3.2
#   openai:              https://api.openai.com/v1             | gpt-4o
#   anthropic:           https://api.anthropic.com              | claude-sonnet-4-20250514
#   gemini:              https://generativelanguage.googleapis.com | gemini-2.0-flash
#   openai_compatible:   (your endpoint)                       | (your model)
ANSWER_LLM_BASE_URL=http://host.docker.internal:11434/v1
ANSWER_LLM_MODEL=llama3.2

# API key (required for openai, anthropic, gemini; optional for ollama)
ANSWER_LLM_API_KEY=

# ── Database (Defaults are fine for local use) ──────────────────
POSTGRES_USER=ragkb
POSTGRES_PASSWORD=changeme
POSTGRES_DB=ragkb

# ── Optional ────────────────────────────────────────────────────
# QDRANT_API_KEY=
# EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
# EMBEDDING_DIMENSIONS=384
# CORS_ORIGINS=http://localhost:3000
# MAX_UPLOAD_SIZE_MB=50
# HF_TOKEN=
