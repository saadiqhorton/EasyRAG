# RAG Knowledge Base Framework - Environment Variables
# Copy this file to .env and fill in the values before running docker-compose.

# --- PostgreSQL (REQUIRED) ---
POSTGRES_USER=ragkb
POSTGRES_PASSWORD=changeme_use_a_strong_password
POSTGRES_DB=ragkb
# Full connection URL (used by backend directly):
POSTGRES_URL=postgresql+asyncpg://ragkb:changeme_use_a_strong_password@localhost:5432/ragkb

# --- Qdrant (REQUIRED base, optional auth) ---
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# --- Embedding Model (optional defaults) ---
# EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
# EMBEDDING_DIMENSIONS=384

# --- Reranker Model (optional defaults) ---
# RERANKER_MODEL_NAME=cross-encoder/ms-marco-MiniLM-L-6-v2

# --- Answer LLM (REQUIRED) ---
ANSWER_LLM_BASE_URL=http://localhost:11434/v1
ANSWER_LLM_MODEL=llama3.2
ANSWER_LLM_API_KEY=

# --- Upload Limits (optional defaults) ---
# MAX_UPLOAD_SIZE_MB=50

# --- Storage Path (optional defaults) ---
# STORAGE_PATH=/data/storage

# --- Worker Settings (optional defaults) ---
# WORKER_POLL_INTERVAL=2

# --- Chunking (optional defaults) ---
# CHUNK_MAX_TOKENS=500
# CHUNK_OVERLAP_TOKENS=150

# --- Retrieval Thresholds (optional defaults) ---
# ABSTENTION_SCORE_THRESHOLD=0.3
# OCR_CONFIDENCE_THRESHOLD=0.5

# --- CORS (optional defaults) ---
# CORS_ORIGINS=http://localhost:3000